#!/bin/bash
# .githooks/post-checkout

# $1 is the previous HEAD commit
# $2 is the new HEAD commit
# $3 is a flag (1 if branch checkout, 0 if file checkout)

# Only run if a branch checkout was performed
if [ "$3" != "1" ]; then
  exit 0
fi

PREV_BRANCH=$(git name-rev --name-only "$1" 2>/dev/null | sed 's/remotes\/origin\///')
BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "master" ]; then
  # Use Vite's native .env.development.local to override keys without ever modifying your .env.development file
  if [ -f ".env.production" ]; then
    cp .env.production .env.development.local
    echo "Switched env to production (master) via .env.development.local override"
  fi
else
  # Switching away from master — remove the override so Vite defaults back to .env.development
  if [ -f ".env.development.local" ]; then
    rm .env.development.local
  fi
  echo "Using default dev environment for $BRANCH"
fi
