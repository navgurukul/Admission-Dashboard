#!/bin/bash
# .githooks/post-checkout

# $1 is the previous HEAD commit
# $2 is the new HEAD commit
# $3 is a flag (1 if branch checkout, 0 if file checkout)

# Only run if a branch checkout was performed
if [ "$3" != "1" ]; then
  exit 0
fi

PREV_BRANCH=$(git name-rev --name-only "$1" 2>/dev/null | sed 's/remotes\/origin\///')
BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "master" ]; then
  # Save current .env.development as dev backup before overwriting
  if [ -f ".env.development" ]; then
    cp .env.development .git/env-dev-backup
  fi
  # Load production environment into .env.development
  if [ -f ".env.production" ]; then
    cp .env.production .env.development
    echo "Switched .env.development to production environment (master)"
  fi
else
  # Switching away from master — restore dev backup if it exists
  if [ "$PREV_BRANCH" = "master" ] && [ -f ".git/env-dev-backup" ]; then
    cp .git/env-dev-backup .env.development
    echo "Restored .env.development for $BRANCH (from dev backup)"
  else
    echo "Using existing .env.development for $BRANCH"
  fi
fi
